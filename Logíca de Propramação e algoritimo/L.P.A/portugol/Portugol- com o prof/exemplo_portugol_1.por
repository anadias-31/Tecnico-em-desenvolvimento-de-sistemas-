programa {
  funcao inicio() {
    inteiro nota1, nota2, nota3, nota4
    real media

    escreva("nota 1:")
    leia (nota1)

    escreva("nota 2:")
    leia (nota2)

    escreva("nota 3:")
    leia (nota3)

    escreva("nota 4:")
    leia (nota4)

    media=(nota1+nota2+nota3+nota4)/4
    escreva("Sua média é:",media)

  }
}
