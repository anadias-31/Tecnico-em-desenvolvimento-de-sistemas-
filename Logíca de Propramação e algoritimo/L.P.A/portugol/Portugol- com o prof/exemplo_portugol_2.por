programa {
  funcao inicio() {
    real baseMaior,baseMenor,altura,area

    escreva("Base maior:")
    leia(baseMaior)

    escreva("Base menor:")
    leia(baseMenor)

    escreva("altura:")
    leia(altura)

    area=((baseMaior+baseMenor)*altura)/2
    escreva("a área do trapezio é:",area)

  }
}
